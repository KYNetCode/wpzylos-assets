{
  "name": "kynetcode/wpzylos-assets",
  "description": "Asset management with Vite support for WPZylos Framework",
  "type": "library",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "wordpress",
    "wpzylos",
    "assets",
    "vite",
    "enqueue",
    "scripts",
    "styles",
    "hmr"
  ],
  "homepage": "https://github.com/KYNetCode/wpzylos-assets",
  "authors": [
    {
      "name": "KYNetCode",
      "email": "diggerwp@gmail.com",
      "homepage": "https://github.com/KYNetCode",
      "role": "Developer"
    }
  ],
  "support": {
    "issues": "https://github.com/KYNetCode/wpzylos-assets/issues",
    "source": "https://github.com/KYNetCode/wpzylos-assets",
    "docs": "https://wpzylos.com/docs/latest/packages/wpzylos-assets"
  },
  "require": {
    "php": "^8.0",
    "kynetcode/wpzylos-core": "^1.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.10",
    "phpunit/phpunit": "^9.6 || ^10.0",
    "squizlabs/php_codesniffer": "^3.7",
    "szepeviktor/phpstan-wordpress": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "WPZylos\\Framework\\Assets\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WPZylos\\Framework\\Assets\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyze": "phpstan analyze",
    "cs": "phpcs --standard=PSR12 src",
    "cs-fix": "phpcbf --standard=PSR12 src",
    "qa": [
      "@cs",
      "@analyze",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.0.2"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "funding": [
    {
      "type": "paypal",
      "url": "https://www.paypal.com/donate/?hosted_button_id=66U4L3HG4TLCC"
    }
  ]
}
